{
  "name": "graft-web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "stylelint": "stylelint \"src/**/*.{vue,css,less}\"",
    "stylelint:fix": "stylelint \"src/**/*.{vue,css,less}\" --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check": "bun run format:check && bun run typecheck && bun run lint && bun run stylelint && bun run test:run && bun run build",
    "prepare": "cd .. && web/node_modules/.bin/husky"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "pinia": "^2.3.1",
    "tdesign-icons-vue-next": "^0.4.4",
    "tdesign-vue-next": "^1.19.2",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^9.27.0",
    "@types/node": "^22.15.3",
    "@unocss/preset-uno": "^66.5.1",
    "@unocss/vite": "^66.5.1",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^3.1.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "eslint-plugin-vue": "^9.33.0",
    "eslint-plugin-vue-scoped-css": "^2.10.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.0.0",
    "postcss-html": "^1.8.0",
    "postcss-less": "^6.0.0",
    "prettier": "^3.5.3",
    "stylelint": "^16.19.1",
    "stylelint-config-standard": "^38.0.0",
    "stylelint-order": "^7.0.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0",
    "unocss": "^66.5.1",
    "vite": "^5.4.19",
    "vitest": "^3.1.4",
    "vue-tsc": "^2.2.10"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,mts,cts,tsx,vue}": [
      "prettier --write",
      "eslint --fix --max-warnings 0"
    ],
    "*.{css,less,md,json,yml,yaml}": [
      "prettier --write"
    ],
    "*.{vue,css,less}": [
      "stylelint --fix"
    ]
  }
}
