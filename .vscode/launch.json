{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "server: 项目启动",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/server/cmd/graft",
            "cwd": "${workspaceFolder}/server",
            "args": [
                "serve"
            ]
        },
        {
            "name": "server: 开发监督器",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/server/cmd/graft",
            "cwd": "${workspaceFolder}/server",
            "args": [
                "dev"
            ]
        },
        {
            "name": "server: 迁移",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/server/cmd/graft",
            "cwd": "${workspaceFolder}/server",
            "args": [
                "migrate",
                "up"
            ]
        },
        {
            "name": "server: 重置管理员",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/server/cmd/graft",
            "cwd": "${workspaceFolder}/server",
            "args": [
                "dev",
                "reset-admin"
            ]
        },
        {
            "name": "server: Air 热重载",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/server/cmd/graft",
            "cwd": "${workspaceFolder}/server",
            "args": [
                "dev",
                "air"
            ]
        },
        {
            "name": "server: 通知开发监督器",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/server/cmd/graft",
            "cwd": "${workspaceFolder}/server",
            "args": [
                "dev",
                "notify"
            ]
        },
        {
            "name": "server: 停止 Air",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/server/cmd/graft",
            "cwd": "${workspaceFolder}/server",
            "args": [
                "dev",
                "stop-air"
            ]
        },
        {
            "name": "server: 生成 JWT 密钥",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/server/cmd/graft-jwt-secret",
            "cwd": "${workspaceFolder}/server"
        },
        {
            "name": "server: 生成签名密钥",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/server/cmd/graft-signing-key",
            "cwd": "${workspaceFolder}/server"
        },
        {
            "name": "web: dev",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "bash",
            "runtimeArgs": [
                "-lc",
                "cd \"${workspaceFolder}/web\" && bun run dev"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "quality: eff-u-code server",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "bash",
            "runtimeArgs": [
                "-lc",
                "cd \"${workspaceFolder}\" && python3 scripts/run_eff_u_code.py server"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "quality: eff-u-code web",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "bash",
            "runtimeArgs": [
                "-lc",
                "cd \"${workspaceFolder}\" && python3 scripts/run_eff_u_code.py web"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "quality: eff-u-code all",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "bash",
            "runtimeArgs": [
                "-lc",
                "cd \"${workspaceFolder}\" && python3 scripts/run_eff_u_code.py all"
            ],
            "console": "integratedTerminal"
        }
    ],
    "compounds": [
        {
            "name": "fullstack: dev",
            "configurations": [
                "server: 开发监督器",
                "web: dev"
            ]
        }
    ]
}
